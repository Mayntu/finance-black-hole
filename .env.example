BOT_TOKEN=
OPENAI_API_KEY=

DATABASE_URL=postgresql+asyncpg://fbh:fbhpass@postgres:5432/financeblackhole
REDIS_URL=redis://redis:6379/0

WEBHOOK_URL=https://yourdomain.com
WEBHOOK_SECRET=change_me_to_random_string

# Public HTTPS URL for the Telegram Mini App.
# Must be HTTPS for web_app buttons and MenuButtonWebApp to work.
# If same server → can equal WEBHOOK_URL.
WEBAPP_URL=https://yourdomain.com

JWT_SECRET=change_me_to_another_random_string

# For local dev without docker, override host:
# DATABASE_URL=postgresql+asyncpg://fbh:fbhpass@localhost:5432/financeblackhole
# REDIS_URL=redis://localhost:6379/0
